<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KoordyApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryVariant">@color/btn_primary_end</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="KoordyCard">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="KoordyButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/btn_primary_start</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">999dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="StepActive">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">6dp</item>
        <item name="android:background">@drawable/step_active</item>
    </style>

    <style name="StepInactive">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">6dp</item>
        <item name="android:background">@drawable/step_inactive</item>
    </style>
</resources>