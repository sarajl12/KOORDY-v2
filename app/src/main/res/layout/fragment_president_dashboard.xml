<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/panel"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="48dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tableau de Bord"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_asso_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#BBDEFB"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- CONTENU -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-24dp"
            android:background="@drawable/bg_bottom_sheet"
            android:paddingTop="24dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- STATS CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="6dp"
                    android:elevation="2dp">

                    <TextView
                        android:id="@+id/tv_stat_membres"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/brand"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Membres"
                        android:textColor="@color/muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="3dp"
                    android:elevation="2dp">

                    <TextView
                        android:id="@+id/tv_stat_events"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/brand"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ce mois"
                        android:textColor="@color/muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- KPI 3 : À venir (était "En attente") -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:elevation="2dp">

                    <TextView
                        android:id="@+id/tv_stat_upcoming"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/brand"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="À venir"
                        android:textColor="@color/muted"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ACTIONS RAPIDES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Actions rapides"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line" />

                <!-- Créer une équipe -->
                <LinearLayout
                    android:id="@+id/btn_creer_equipe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center"
                        android:text="⚑"
                        android:textColor="@color/brand"
                        android:textSize="18sp"
                        android:layout_marginEnd="14dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Créer une équipe"
                        android:textColor="@color/text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/muted"
                        android:textSize="22sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginStart="72dp" />

                <!-- Envoyer une annonce -->
                <LinearLayout
                    android:id="@+id/btn_send_annonce"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center"
                        android:text="✉"
                        android:textColor="@color/brand"
                        android:textSize="18sp"
                        android:layout_marginEnd="14dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Envoyer une annonce"
                        android:textColor="@color/text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/muted"
                        android:textSize="22sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginStart="72dp" />

                <!-- Créer une actualité (était "Actualités en attente") -->
                <LinearLayout
                    android:id="@+id/btn_creer_actualite"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center"
                        android:text="✏"
                        android:textColor="@color/brand"
                        android:textSize="16sp"
                        android:layout_marginEnd="14dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Créer une actualité"
                        android:textColor="@color/text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/muted"
                        android:textSize="22sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- MEMBRES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Membres"
                        android:textColor="@color/text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_membres_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/muted"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_membres"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:nestedScrollingEnabled="true"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/tv_no_membres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Aucun membre"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- MES ÉQUIPES (remplace "Actualités en attente") -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mes équipes"
                        android:textColor="@color/text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_equipes_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/muted"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_equipes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingVertical="6dp" />

                <TextView
                    android:id="@+id/tv_no_equipes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Aucune équipe créée"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
