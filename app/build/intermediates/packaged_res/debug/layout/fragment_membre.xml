<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/panel"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="36dp"
            android:paddingBottom="48dp"
            android:paddingHorizontal="24dp">

            <!-- Avatar cliquable -->
            <FrameLayout
                android:id="@+id/avatar_container"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Cercle blanc (fond) -->
                <FrameLayout
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_profile"
                    android:elevation="4dp"
                    android:clipToOutline="true">

                    <!-- Photo si chargée -->
                    <ImageView
                        android:id="@+id/iv_avatar_photo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <!-- Initiale (affiché si pas de photo) -->
                    <TextView
                        android:id="@+id/tv_avatar_initial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="#2D9CF0"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Badge caméra bottom-right -->
                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_button_primary"
                    android:elevation="6dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="✎"
                        android:textColor="@color/white"
                        android:textSize="13sp" />
                </FrameLayout>

            </FrameLayout>

            <!-- Nom complet -->
            <TextView
                android:id="@+id/tv_full_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Chargement…"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Badge rôle -->
            <TextView
                android:id="@+id/tv_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_role_badge"
                android:paddingHorizontal="14dp"
                android:paddingVertical="4dp"
                android:text="Membre"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Date adhésion -->
            <TextView
                android:id="@+id/tv_adhesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#BBDEFB"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- ── CONTENU (overlap sur le header) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-24dp"
            android:background="@drawable/bg_bottom_sheet"
            android:paddingTop="28dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- ── CARD INFOS PERSONNELLES ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:elevation="2dp">

                <!-- Header carte -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Coordonnées"
                        android:textColor="@color/text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_edit_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_button_primary"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Modifier"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line" />

                <!-- Row Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center"
                        android:text="✉"
                        android:textColor="#2D9CF0"
                        android:textSize="16sp"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADRESSE EMAIL"
                            android:textColor="@color/muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tv_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginStart="70dp" />

                <!-- Row Date de naissance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center"
                        android:text="◆"
                        android:textColor="#2D9CF0"
                        android:textSize="14sp"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DATE DE NAISSANCE"
                            android:textColor="@color/muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tv_naissance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginStart="70dp" />

                <!-- Row Âge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center"
                        android:text="★"
                        android:textColor="#2D9CF0"
                        android:textSize="15sp"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ÂGE"
                            android:textColor="@color/muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tv_age"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Formulaire d'édition (masqué) -->
                <LinearLayout
                    android:id="@+id/layout_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingHorizontal="18dp"
                    android:paddingBottom="18dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/line"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prénom"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_edit_prenom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:inputType="textPersonName"
                        android:padding="12dp"
                        android:textColor="@color/text"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nom"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_edit_nom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:inputType="textPersonName"
                        android:padding="12dp"
                        android:textColor="@color/text"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_edit_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:inputType="textEmailAddress"
                        android:padding="12dp"
                        android:textColor="@color/text"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date de naissance (AAAA-MM-JJ)"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_edit_birth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:inputType="datetime"
                        android:padding="12dp"
                        android:textColor="@color/text"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btn_cancel_edit"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card"
                            android:gravity="center"
                            android:text="Annuler"
                            android:textColor="@color/muted"
                            android:textSize="13sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/btn_save_profile"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button_primary"
                            android:gravity="center"
                            android:text="Enregistrer"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Vues masquées (compatibilité binding) -->
            <TextView android:id="@+id/tv_nom" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tv_prenom" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

            <!-- ── CARD ASSOCIATION ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:elevation="2dp">

                <!-- Ligne icône + nom asso -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_chat_dialog"
                        android:layout_marginEnd="14dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="#"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MON ASSOCIATION"
                            android:textColor="@color/muted"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:id="@+id/tv_asso_nom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginStart="76dp" />

                <!-- Sport + Ville -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:id="@+id/tv_asso_sport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_sport_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:textColor="#2D9CF0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tv_asso_ville"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/muted"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── CARD ÉQUIPE ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:paddingVertical="16dp"
                android:layout_marginBottom="14dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_box"
                    android:gravity="center"
                    android:text="⚑"
                    android:textColor="#2D9CF0"
                    android:textSize="18sp"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MON ÉQUIPE"
                        android:textColor="@color/muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:id="@+id/tv_equipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── CARD PRÉSENCES ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="18dp"
                android:layout_marginBottom="24dp"
                android:elevation="2dp">

                <!-- Header présences -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mes présences"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <!-- Vues masquées (compatibilité binding) -->
                <TextView android:id="@+id/tv_taux_presence" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <ProgressBar android:id="@+id/progress_presences" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

                <!-- Liste évènements acceptés -->
                <TextView
                    android:id="@+id/tv_presences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- ── BOUTON DÉCONNEXION ── -->
            <TextView
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_btn_logout"
                android:gravity="center"
                android:text="Se déconnecter"
                android:textColor="@color/danger"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
