<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/panel"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="48dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Créer une actualité"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Publiée immédiatement sur la page d'accueil"
                android:textColor="#BBDEFB"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- FORMULAIRE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-24dp"
            android:background="@drawable/bg_bottom_sheet"
            android:paddingTop="24dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- Image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Image (optionnel)"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp" />

                <!-- Zone image -->
                <FrameLayout
                    android:id="@+id/frame_image"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Placeholder -->
                    <LinearLayout
                        android:id="@+id/layout_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🖼"
                            android:textSize="36sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Appuyer pour choisir une image"
                            android:textColor="@color/muted"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Image sélectionnée -->
                    <ImageView
                        android:id="@+id/iv_image_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/btn_supprimer_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="14dp"
                    android:text="Supprimer l'image"
                    android:textColor="@color/danger"
                    android:textSize="12sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Titre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:elevation="2dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Titre *"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_titre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="Titre de l'actualité"
                    android:inputType="textCapSentences"
                    android:padding="12dp"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Contenu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:layout_marginBottom="20dp"
                android:elevation="2dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contenu"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_contenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="Décrivez votre actualité…"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="4"
                    android:maxLines="10"
                    android:gravity="top"
                    android:padding="12dp"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Bouton publier -->
            <TextView
                android:id="@+id/btn_publier"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_primary"
                android:gravity="center"
                android:text="Publier l'actualité"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
