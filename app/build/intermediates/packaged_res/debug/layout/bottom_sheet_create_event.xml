<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="#D1D5DB" />

    <!-- Titre du bottom sheet -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nouvel événement"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Renseignez les infos et sélectionnez les participants"
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Zone scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp">

            <!-- Section infos -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMATIONS"
                android:textColor="@color/brand"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <!-- Titre -->
            <EditText
                android:id="@+id/et_titre"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Titre de l'événement *"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:inputType="textCapSentences"
                android:layout_marginBottom="10dp" />

            <!-- Type (chips) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="10dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_match"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Match"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_entrainement"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entraînement"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_reunion"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Réunion"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_autre"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Autre"
                        android:textSize="13sp" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Lieu -->
            <EditText
                android:id="@+id/et_lieu"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Lieu (optionnel)"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:inputType="textCapSentences"
                android:layout_marginBottom="10dp" />

            <!-- Date + Heure -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tv_date_picker"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:hint="Date *"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:textSize="14sp"
                    android:paddingHorizontal="14dp" />

                <TextView
                    android:id="@+id/tv_time_picker"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:hint="Heure *"
                    android:textColor="@color/text"
                    android:textColorHint="@color/muted"
                    android:textSize="14sp"
                    android:paddingHorizontal="14dp" />

            </LinearLayout>

            <!-- Description -->
            <EditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:background="@drawable/bg_input"
                android:hint="Description (optionnel)"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="14sp"
                android:padding="14dp"
                android:inputType="textCapSentences|textMultiLine"
                android:gravity="top"
                android:layout_marginBottom="24dp" />

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/line"
                android:layout_marginBottom="20dp" />

            <!-- Section participants -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PARTICIPANTS"
                        android:textColor="@color/brand"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/tv_selected_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tous les membres invités par défaut"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_select_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tout sélectionner"
                    android:textColor="@color/brand"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- Chargement membres -->
            <ProgressBar
                android:id="@+id/progress_members"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Liste membres -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_members"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:layout_marginBottom="20dp" />

            <!-- Bouton juste après la liste -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="24dp"
                android:text="Créer l'événement"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#2D9CF0"
                app:cornerRadius="27dp"
                android:elevation="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
