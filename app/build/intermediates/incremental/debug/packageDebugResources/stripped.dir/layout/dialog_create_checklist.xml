<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Nouvelle checklist"
        android:textColor="@color/text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="20dp" />

    <!-- Event name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Événement *"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <EditText
        android:id="@+id/et_nom_evenement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input"
        android:hint="ex: Match contre Paris FC"
        android:textColor="@color/text"
        android:textColorHint="@color/muted"
        android:textSize="14sp"
        android:padding="12dp"
        android:inputType="text"
        android:layout_marginBottom="14dp" />

    <!-- Date picker button -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date et heure de l'événement"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/btn_select_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input"
        android:text="📅  Sélectionner la date et l'heure"
        android:textColor="@color/muted"
        android:textSize="14sp"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="14dp" />

    <!-- Lieu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lieu"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <EditText
        android:id="@+id/et_lieu_evenement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input"
        android:hint="ex: Stade Municipal de Lyon"
        android:textColor="@color/text"
        android:textColorHint="@color/muted"
        android:textSize="14sp"
        android:padding="12dp"
        android:layout_marginBottom="24dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Annuler"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:padding="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_create"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Créer"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:paddingVertical="10dp"
            android:paddingHorizontal="24dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
