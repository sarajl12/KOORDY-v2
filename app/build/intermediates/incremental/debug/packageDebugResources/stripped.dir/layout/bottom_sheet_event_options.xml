<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="#E0E0E0" />

    <!-- Header événement -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tv_opts_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_opts_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:background="@color/muted"
                android:layout_marginHorizontal="6dp" />

            <TextView
                android:id="@+id/tv_opts_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_opts_lieu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:layout_marginTop="3dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F4F8" />

    <!-- Option Modifier -->
    <LinearLayout
        android:id="@+id/btn_modifier"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✏️"
            android:textSize="16sp"
            android:layout_marginEnd="14dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Modifier l'événement"
            android:textColor="@color/text"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F4F8"
        android:layout_marginHorizontal="20dp" />

    <!-- Option Envoyer par chat -->
    <LinearLayout
        android:id="@+id/btn_envoyer_chat"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="💬"
            android:textSize="16sp"
            android:layout_marginEnd="14dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Envoyer comme invitation par chat"
            android:textColor="@color/text"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Section sélection membre (cachée par défaut) -->
    <LinearLayout
        android:id="@+id/section_membres"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F4F8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choisir un membre"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.06"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="6dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_membres_send"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/tv_membres_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aucun membre disponible."
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progress_membres"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="8dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
