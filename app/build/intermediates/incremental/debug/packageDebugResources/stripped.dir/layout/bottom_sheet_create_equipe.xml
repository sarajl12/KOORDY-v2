<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@color/line" />

    <!-- Titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Créer une équipe"
        android:textColor="@color/text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="20dp" />

    <!-- Nom de l'équipe -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nom de l'équipe *"
        android:textColor="@color/muted"
        android:textSize="12sp"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_nom_equipe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input"
        android:hint="ex. Équipe A"
        android:inputType="textCapSentences"
        android:padding="12dp"
        android:textColor="@color/text"
        android:textColorHint="@color/muted"
        android:textSize="14sp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description (optionnel)"
        android:textColor="@color/muted"
        android:textSize="12sp"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input"
        android:hint="Décrivez cette équipe…"
        android:inputType="textMultiLine|textCapSentences"
        android:minLines="2"
        android:maxLines="4"
        android:padding="12dp"
        android:textColor="@color/text"
        android:textColorHint="@color/muted"
        android:textSize="14sp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp" />

    <!-- Sélection des membres -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Membres à ajouter"
        android:textColor="@color/muted"
        android:textSize="12sp"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="4dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_membres_select"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:nestedScrollingEnabled="true"
        android:layout_marginBottom="20dp" />

    <!-- Bouton créer -->
    <TextView
        android:id="@+id/btn_create"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_button_primary"
        android:gravity="center"
        android:text="Créer l'équipe"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginHorizontal="20dp" />

</LinearLayout>
