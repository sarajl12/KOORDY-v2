<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingBottom="24dp">

    <!-- Logo en haut -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#F0F8FF">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:elevation="4dp" />

    </FrameLayout>

    <!-- Badge nombre de messages -->
    <TextView
        android:id="@+id/tvBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="-10dp"
        android:background="@drawable/bg_badge_blue"
        android:paddingHorizontal="12dp"
        android:paddingVertical="3dp"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:text="NOUVEAU"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center" />

    <!-- Titre -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:text="Vous avez des messages"
        android:textColor="@color/text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Sous-titre -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:text="Des membres de ton association t'ont écrit."
        android:textColor="@color/muted"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3" />

    <!-- Séparateur -->
    <View
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:background="#2D9CF0" />

    <!-- Boutons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center">

        <!-- Plus tard -->
        <TextView
            android:id="@+id/btnDismiss"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Plus tard"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:background="@drawable/bg_card"
            android:layout_marginEnd="8dp" />

        <!-- Voir les messages -->
        <TextView
            android:id="@+id/btnGoToChat"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Voir les messages"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
