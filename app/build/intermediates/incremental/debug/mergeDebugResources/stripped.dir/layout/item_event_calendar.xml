<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:layout_marginBottom="12dp"
    android:clipToOutline="true">

    <!-- Barre colorée statut RSVP -->
    <View
        android:id="@+id/view_status_bar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/brand" />

    <!-- Contenu principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Ligne du haut : date + infos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Bloc date -->
            <LinearLayout
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-2dp" />

                <TextView
                    android:id="@+id/tv_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true" />

            </LinearLayout>

            <!-- Séparateur vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/line"
                android:layout_marginHorizontal="14dp" />

            <!-- Titre + badges -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tv_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:background="@color/muted"
                        android:layout_marginHorizontal="6dp" />

                    <TextView
                        android:id="@+id/tv_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/muted"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Bouton options ⋮ -->
            <TextView
                android:id="@+id/btn_options"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="⋮"
                android:textSize="18sp"
                android:textColor="@color/muted"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Lieu -->
        <TextView
            android:id="@+id/tv_lieu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:drawablePadding="4dp"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Séparateur section RSVP -->
        <View
            android:id="@+id/view_rsvp_sep"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/line"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <!-- Statut : "Accepté" / "Refusé" (quand déjà répondu) -->
        <LinearLayout
            android:id="@+id/ll_statut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <View
                android:id="@+id/view_statut_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_statut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Boutons RSVP (quand "En attente") -->
        <LinearLayout
            android:id="@+id/ll_rsvp_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_refuse"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Décliner"
                android:textColor="@color/muted"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_refuse"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btn_accept"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Participer"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_accept"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
