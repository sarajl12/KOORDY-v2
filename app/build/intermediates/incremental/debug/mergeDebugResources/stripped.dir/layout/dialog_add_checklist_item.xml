<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➕ Ajouter un élément"
        android:textColor="@color/text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="20dp" />

    <!-- Item name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Matériel à apporter *"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <EditText
        android:id="@+id/et_nom_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input"
        android:hint="ex: Maillots, ballons, filet..."
        android:textColor="@color/text"
        android:textColorHint="@color/muted"
        android:textSize="14sp"
        android:padding="12dp"
        android:inputType="text"
        android:layout_marginBottom="14dp" />

    <!-- Comment -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Commentaire (optionnel)"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <EditText
        android:id="@+id/et_commentaire"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input"
        android:hint="Détails supplémentaires..."
        android:textColor="@color/text"
        android:textColorHint="@color/muted"
        android:textSize="14sp"
        android:padding="12dp"
        android:minLines="2"
        android:inputType="textMultiLine"
        android:gravity="top|start"
        android:layout_marginBottom="24dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Annuler"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:padding="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajouter"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:paddingVertical="10dp"
            android:paddingHorizontal="24dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
