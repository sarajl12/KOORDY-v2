<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="28dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- En-tête conversation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="18dp">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <TextView
                android:id="@+id/tvHeaderAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_avatar_initial"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/ivHeaderAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="gone"
                android:scaleType="centerCrop"/>

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvHeaderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvHeaderType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/line"
        android:layout_marginBottom="6dp"/>

    <!-- ── Option Épingler ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/optionPin"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_option_row"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_option">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_pin"
                android:tint="@color/brand"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvPinLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Épingler"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvPinSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apparaît toujours en haut de la liste"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Badge état actif -->
        <TextView
            android:id="@+id/tvPinActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actif"
            android:textColor="@color/brand"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ── Option Silencieux ───────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/optionMute"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_option_row"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_option">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell_off"
                android:tint="@color/brand"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvMuteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mettre en silencieux"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMuteSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Désactiver les notifications"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvMuteActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actif"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Séparateur avant supprimer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/line"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <!-- ── Option Supprimer ────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/optionDelete"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_option_row_danger"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_option_danger">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_trash"
                android:tint="@color/danger"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supprimer la conversation"
                android:textColor="@color/danger"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suppression définitive pour tous"
                android:textColor="@color/danger"
                android:alpha="0.65"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
