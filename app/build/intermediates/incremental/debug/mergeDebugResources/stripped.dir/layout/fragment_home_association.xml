<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════════════════ HERO BANNER ═══════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <!-- Banner image (association logo fills banner) -->
            <ImageView
                android:id="@+id/iv_asso_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#2D9CF0" />

            <!-- Dark gradient overlay (bottom-to-top) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_hero_gradient" />

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- Association name + avatar (bottom overlay) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_asso_avatar"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:background="@drawable/bg_avatar_round"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASSOCIATION"
                        android:textColor="#AAFFFFFF"
                        android:textSize="10sp"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/tv_asso_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_asso_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ═══════════════════════ STATS BAR ═══════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/panel"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_chip"
                android:paddingVertical="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tv_stat_membres"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/brand"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Membres"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_chip"
                android:paddingVertical="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tv_stat_events"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/brand"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="À venir"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_chip"
                android:paddingVertical="12dp">

                <TextView
                    android:id="@+id/tv_stat_news"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/brand"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Actus"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═════════════════ PROCHAIN ÉVÉNEMENT ═════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prochain événement"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <!-- Featured event card -->
            <LinearLayout
                android:id="@+id/card_next_event"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_next_event_card"
                android:orientation="horizontal"
                android:padding="18dp"
                android:visibility="gone">

                <!-- Date column -->
                <LinearLayout
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:id="@+id/tv_next_event_day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_next_event_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <!-- Event info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_next_event_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_next_event_lieu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_next_event_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:paddingBottom="10dp" />

                    <TextView
                        android:id="@+id/tv_next_event_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_event_type_badge"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_events_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aucun événement à venir pour le moment."
                android:textColor="@color/muted"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ═════════════════ À NE PAS OUBLIER ═════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="4dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 À ne pas oublier"
                        android:textColor="@color/text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Matériel à apporter pour vos événements"
                        android:textColor="@color/muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_new_checklist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Nouvelle"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tv_checklist_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aucune checklist · Créez-en une pour préparer votre prochain événement !"
                android:textColor="@color/muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Checklist card -->
            <LinearLayout
                android:id="@+id/card_checklist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Event info header (dark) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_checklist_header"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tv_checklist_event_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/tv_checklist_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="#BBFFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_checklist_lieu"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="#BBFFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_checklist_progress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Items list (LinearLayout pour éviter le bug RecyclerView dans ScrollView) -->
                <LinearLayout
                    android:id="@+id/ll_checklist_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="4dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginHorizontal="16dp" />

                <!-- Add item button -->
                <TextView
                    android:id="@+id/btn_add_item"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Ajouter un élément"
                    android:textColor="#2D9CF0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Navigation entre checklists -->
            <LinearLayout
                android:id="@+id/ll_checklist_nav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_prev_checklist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Préc."
                    android:textColor="#2D9CF0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_checklist_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_next_checklist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suiv. →"
                    android:textColor="#2D9CF0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═════════════════ DERNIÈRE ACTUALITÉ ═════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="4dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Actualités"
                    android:textColor="@color/text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_voir_tout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voir tout →"
                    android:textColor="@color/brand"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Last news card (clickable, navigates to all news) -->
            <LinearLayout
                android:id="@+id/card_last_news"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <!-- News image (shown only if available) -->
                <ImageView
                    android:id="@+id/iv_news_image"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- News text content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/tv_news_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tv_news_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_news_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:paddingBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_news_excerpt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/muted"
                        android:textSize="13sp"
                        android:maxLines="3"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_news_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aucune actualité pour le moment."
                android:textColor="@color/muted"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ═════════════════ CONSEIL DU CLUB ═════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conseil du club"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_conseil_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aucun membre du conseil."
                android:textColor="@color/muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_conseil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- ═════════════════ À PROPOS ═════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="36dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="À propos"
                    android:textColor="@color/text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_edit_asso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Modifier"
                    android:textColor="@color/brand"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/muted"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"
                    android:paddingBottom="14dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Adresse"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tv_adresse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_ville"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_pays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:paddingBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/line"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 Téléphone"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tv_telephone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
